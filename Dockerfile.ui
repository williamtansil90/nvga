FROM python:3.12-slim-bookworm

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir flask httpx

COPY ui.py .
COPY templates/ templates/
COPY static/ static/

RUN mkdir -p static/outputs

ENV UI_HOST=0.0.0.0 \
    UI_PORT=5000 \
    FLASK_DEBUG=0 \
    API_URL=http://api:8001

EXPOSE 5000

CMD ["python", "ui.py"]
