# Salin ke .env lalu isi GEMINI_API_KEY
# cp .env.example .env

# Wajib — dipakai UI saat generate video
GEMINI_API_KEY=AIza...

# Opsional
GEMINI_MODEL=gemini-flash-latest
API_PORT=8000
UI_PORT=5000

# Path default media di container (biasanya tidak perlu diubah)
# BG_VIDEO_DEFAULT=/app/media/background-video.mp4
# AUDIO_DEFAULT=/app/media/music.mp3
